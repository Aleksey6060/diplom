videocall.store {
  reverse_proxy frontend:80
}

api.videocall.store {
  @preflight method OPTIONS
  handle @preflight {
    header Access-Control-Allow-Origin "https://videocall.store"
    header Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS"
    header Access-Control-Allow-Headers "Authorization,Content-Type,X-Requested-With,X-CSRFToken"
    header Access-Control-Allow-Credentials "true"
    respond "" 204
  }

  header {
    Access-Control-Allow-Origin "https://videocall.store"
    Access-Control-Allow-Credentials "true"
    Vary "Origin"
  }

  handle_path /static/* {
    root * /static
    file_server
  }

  handle_path /media/* {
    root * /media
    file_server
  }

  reverse_proxy /ws/* backend:8000
  reverse_proxy backend:8000
}
